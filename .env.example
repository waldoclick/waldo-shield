# Domain to scan (waldo.click or waldoclick.dev)
DOMAIN=waldoclick.dev

# Cloudflare API token
# Create at: https://dash.cloudflare.com/profile/api-tokens
# Required permissions: Zone:Read, Analytics:Read, Firewall Services:Read, Config Rules:Read
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here

# Cloudflare Zone ID
# Find at: Cloudflare Dashboard → Select zone → Overview → Zone ID (right sidebar)
CLOUDFLARE_ZONE_ID=your_zone_id_here

# Mailgun API key
# Find at: https://app.mailgun.com/settings/api_security
MAILGUN_API_KEY=your_mailgun_api_key_here

# GitHub Personal Access Token
# Create at: https://github.com/settings/tokens
# Required scopes: repo (for private repos) or public_repo (for public only)
GITHUB_TOKEN=your_github_token_here
